<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        body { margin: 0; background: #1a1a2e; display: flex; justify-content: center; align-items: center; height: 100vh; }
        canvas { background: #16213e; cursor: pointer; border-radius: 20px; }
        #info { position: absolute; top: 20px; color: white; font-family: monospace; }
    </style>
</head>
<body>
<canvas id="gameCanvas" width="400" height="600"></canvas>
<div id="info">Score: <span id="score">0</span> | Tap the squares!</div>
<script>
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    let score = 0;
    let targets = [
        { x: 100, y: 200, w: 60, h: 60, hit: false },
        { x: 240, y: 350, w: 60, h: 60, hit: false },
        { x: 170, y: 480, w: 60, h: 60, hit: false }
    ];
    
    function draw() {
        ctx.clearRect(0, 0, 400, 600);
        targets.forEach(t => {
            if (!t.hit) {
                ctx.fillStyle = '#e94560';
                ctx.fillRect(t.x, t.y, t.w, t.h);
                ctx.fillStyle = '#fff';
                ctx.font = '30px Arial';
                ctx.fillText('+1', t.x+15, t.y+45);
            }
        });
        document.getElementById('score').innerText = score;
        
        // Победа — все предметы собраны
        if (score === targets.length) {
            ctx.fillStyle = 'rgba(0,0,0,0.7)';
            ctx.fillRect(0, 0, 400, 600);
            ctx.fillStyle = 'white';
            ctx.font = '24px monospace';
            ctx.fillText('You win! Install now?', 70, 280);
            // Это место для вызова CTA (кнопки установки)
            if (typeof ironsource !== 'undefined') {
                ironsource.playable.complete();
            }
        }
    }
    
    function handleTap(e) {
        const rect = canvas.getBoundingClientRect();
        const scaleX = canvas.width / rect.width;
        const scaleY = canvas.height / rect.height;
        let clientX, clientY;
        if (e.touches) {
            clientX = e.touches[0].clientX;
            clientY = e.touches[0].clientY;
        } else {
            clientX = e.clientX;
            clientY = e.clientY;
        }
        const tapX = (clientX - rect.left) * scaleX;
        const tapY = (clientY - rect.top) * scaleY;
        
        for (let i = 0; i < targets.length; i++) {
            const t = targets[i];
            if (!t.hit && tapX > t.x && tapX < t.x+t.w && tapY > t.y && tapY < t.y+t.h) {
                t.hit = true;
                score++;
                draw();
                break;
            }
        }
    }
    
    canvas.addEventListener('click', handleTap);
    canvas.addEventListener('touchstart', handleTap);
    draw();
    
    // Симуляция IronSource SDK
    window.ironsource = window.ironsource || { playable: { start: ()=>{}, complete: ()=>{} } };
    ironsource.playable.start();
</script>
</body>
</html>
